# Neon Postgres (pooled + direct). The pooled URL goes to DATABASE_URL and is
# used by the Prisma Client at runtime; the direct URL is only used by
# `prisma migrate`.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Resend API key — https://resend.com/api-keys (Full access is easiest for dev).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Default "from" address. Must be on a verified Resend domain, e.g. "You <you@yourdomain.com>".
RESEND_FROM="You <you@yourdomain.com>"

# Webhook signing secret from the Resend dashboard (starts with "whsec_").
# https://resend.com/webhooks
RESEND_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
